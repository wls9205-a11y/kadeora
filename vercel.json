{
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    },
    "src/app/(main)/**/*.tsx": {
      "maxDuration": 30
    },
    "src/app/admin/**/*.tsx": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/seed-posts",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/invite-reward",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 3 * * *"
    }
  ]
}
