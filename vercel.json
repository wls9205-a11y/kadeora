{
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    },
    "src/app/api/cron/blog-*/*.ts": {
      "maxDuration": 300
    },
    "src/app/(main)/**/*.tsx": {
      "maxDuration": 30
    },
    "src/app/admin/**/*.tsx": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/seed-posts",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/invite-reward",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/cleanup-pageviews",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/stock-refresh",
      "schedule": "*/5 9-16 * * 1-5"
    },
    {
      "path": "/api/cron/push-apt-deadline",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/push-daily-reminder",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/blog-daily",
      "schedule": "30 7 * * 1-5"
    },
    {
      "path": "/api/cron/blog-apt-new",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/blog-weekly",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/blog-monthly",
      "schedule": "0 9 1 * *"
    },
    {
      "path": "/api/cron/blog-afternoon",
      "schedule": "0 14 * * 1-5"
    },
    {
      "path": "/api/cron/blog-monthly-theme",
      "schedule": "0 10 1 * *"
    }
  ]
}
