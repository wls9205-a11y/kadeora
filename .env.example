# ============================================================
# KADEORA 환경변수 템플릿
# .env.local에 복사하여 실제 값을 입력하세요
# ⚠️ 보안팀 주의: 이 파일을 절대 커밋하지 마세요
# ============================================================

# Supabase (공개 — RLS로 보호)
NEXT_PUBLIC_SUPABASE_URL=https://tezftxakuwhsclarprlz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase (서버 전용 — 절대 NEXT_PUBLIC_ 접두사 금지!)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Site
NEXT_PUBLIC_SITE_URL=https://kadeora.vercel.app

# Kakao (마케팅팀: 카카오 공유)
NEXT_PUBLIC_KAKAO_JS_KEY=your_kakao_js_key_here

# Toss Payments (결제)
TOSS_SECRET_KEY=your_toss_secret_key_here

# Cron Secret (Edge Function 인증)
CRON_SECRET=your_cron_secret_here

# Upstash Redis (Kim Zetter: 분산 Rate Limiting)
UPSTASH_REDIS_REST_URL=your_upstash_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ============================================================
# 보안팀 체크리스트:
# □ SUPABASE_SERVICE_ROLE_KEY에 NEXT_PUBLIC_ 접두사 없는지 확인
# □ CRON_SECRET이 충분히 길고 랜덤한지 확인 (최소 32자)
# □ 모든 키가 Vercel 환경변수에 등록되었는지 확인
# □ 분기별 키 로테이션 일정 수립되었는지 확인
# ============================================================
